<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <title>Danh sách vé</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <h1>Quản lý vé sự kiện</h1>

    <form method="GET" action="/tickets" class="toolbar">
        <input type="text" name="keyword"
            placeholder="Tìm theo tên sự kiện hoặc địa điểm..."
            value="<%= keyword %>">

        <select name="type">
            <option value="">Tất cả</option>
            <option value="Standard" <%= type === "Standard" ? "selected" : "" %>>Standard</option>
            <option value="VIP" <%= type === "VIP" ? "selected" : "" %>>VIP</option>
            <option value="Student" <%= type === "Student" ? "selected" : "" %>>Student</option>
        </select>

        <button type="submit" class="btn">Tìm</button>
        <a href="/add" class="btn btn-primary">+ Thêm mới</a>
    </form>

    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Sự kiện</th>
                    <th>Địa điểm</th>
                    <th>Ngày</th>
                    <th>Loại vé</th>
                    <th>Số lượng</th>
                    <th>Giá</th>
                    <th>Doanh thu</th>
                    <th>Trạng thái</th>
                    <th>Poster</th>
                    <th>Thao tác</th>
                </tr>
            </thead>

            <tbody>
                <% if (items.length === 0) { %>
                    <tr>
                        <td colspan="11">Không có dữ liệu</td>
                    </tr>
                <% } %>

                <% items.forEach((item) => { %>
                    <tr>
                        <td><%= item.ticketId %></td>

                        <td><%= item.eventName %></td>

                        <td><%= item.location %></td>

                        <td>
                            <%= new Date(item.eventDate).toLocaleDateString("vi-VN") %>
                        </td>

                        <td><%= item.ticketType %></td>

                        <td><%= item.availableQty %></td>

                        <td>
                            <%= Number(item.price).toLocaleString("vi-VN") %>
                        </td>

                        <td>
                            <%= Number(item.revenue).toLocaleString("vi-VN") %>
                        </td>

                        <td><%= item.status %></td>

                        <td>
                            <% if (item.posterUrl) { %>
                                <img src="<%= item.posterUrl %>" width="80" class="cover-image">
                            <% } else { %>
                                Không có ảnh
                            <% } %>
                        </td>

                        <td>
                            <div class="row-actions">
                                <a href="/edit/<%= item.ticketId %>" class="btn btn-sm">Sửa</a>

                                <form action="/delete/<%= item.ticketId %>" method="POST">
                                    <button type="submit"
                                        class="btn btn-sm btn-danger"
                                        onclick="return confirm('Xóa?')">
                                        Xóa
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>

    <div class="summary">
        Tổng doanh thu tiềm năng:
        <strong>
            <%= Number(totalRevenue || 0).toLocaleString("vi-VN") %>
        </strong>
    </div>

</body>

</html>